# Supabase — find these in your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Restricts login to a single email address
ALLOWED_EMAIL=your-authorized-email@example.com

# Demo mode (true = auto-seeds demo data on /seed route)
DEMO_MODE=true

# Demo user credentials — must match your Supabase auth user
DEMO_USER_ID=your-demo-user-uuid
DEMO_EMAIL=your-authorized-email@example.com

# Internal dev secret — used by /api/seed route to authorize seeding
# Change this to a long random string in production
DEV_SECRET_KEY=change-me-to-a-long-random-string

# Supabase service role key — NEVER expose this client-side
# Used server-side only (e.g., /api/seed) with admin privileges
SUPABASE_SERVICE_ROLE_KEY=
