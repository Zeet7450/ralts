# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — NEVER commit real secrets
.env
.env.local
.env.production
.env.production.local
# .env.example is committed (placeholder values only)
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# PWA service worker (generated at build time)
# /public/sw.js is the Ralts push service worker — it is source-tracked, not generated.
/public/workbox-*.js
/public/precache.*.json

# Claude agents / skills — do not commit installed skills
.agents/
